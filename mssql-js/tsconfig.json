{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "./js",
    "types": ["node"]
  },
  "include": ["src/**/*", "js/generated/index.d.ts", "js/**/*.ts"],
  "exclude": ["node_modules", "target", "js/dist"]
}
